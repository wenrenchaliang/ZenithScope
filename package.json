{
  "name": "zenithscope",
  "version": "0.1.0",
  "private": true,
  "description": "ZenithScope 天顶之眼数据可视化大屏",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "screenshot": "node scripts/capture-dashboard.mjs",
    "screenshot:dashboard": "node scripts/capture-dashboard.mjs",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "typecheck": "tsc -b --pretty",
    "quality": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "echarts": "^6.1.0",
    "msw": "^2.14.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
